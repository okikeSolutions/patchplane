# Convex
CONVEX_URL=
VITE_CONVEX_URL=
PATCHPLANE_SYSTEM_INGESTION_SECRET=

# WorkOS / AuthKit
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
WORKOS_COOKIE_PASSWORD=
# Optional alpha workspace routing fallback
PATCHPLANE_WORKOS_ORGANIZATION_ID=

# GitHub App / webhook runtime
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
PATCHPLANE_GITHUB_ALLOWED_REPOSITORIES=owner/repo
# Optional explicit workspace id. Alternative: PATCHPLANE_WORKOS_ORGANIZATION_ID.
PATCHPLANE_GITHUB_WORKSPACE_ID=
# Optional for GitHub Enterprise
GITHUB_BASE_URL=

# Daytona sandbox runtime
DAYTONA_API_KEY=
# DAYTONA_API_URL=
# DAYTONA_TARGET=

# Optional provider key for Pi modes
# OPENAI_API_KEY=
