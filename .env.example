# Convex
CONVEX_URL=
VITE_CONVEX_URL=
PATCHPLANE_SYSTEM_INGESTION_SECRET=

# WorkOS / AuthKit
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
WORKOS_COOKIE_PASSWORD=
# Optional alpha workspace routing fallback
PATCHPLANE_WORKOS_ORGANIZATION_ID=

# GitHub App / webhook runtime
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Hosted GitHub App install flow. Use either slug or explicit install URL.
PATCHPLANE_GITHUB_APP_SLUG=
PATCHPLANE_GITHUB_APP_INSTALL_URL=
# Public app origin for live smoke/checklists, e.g. https://<id>.ngrok-free.app
PATCHPLANE_PUBLIC_APP_URL=
PATCHPLANE_GITHUB_ALLOWED_REPOSITORIES=owner/repo
# Optional explicit workspace id. Alternative: PATCHPLANE_WORKOS_ORGANIZATION_ID.
PATCHPLANE_GITHUB_WORKSPACE_ID=
# Optional for GitHub Enterprise
GITHUB_BASE_URL=

# Daytona sandbox runtime
DAYTONA_API_KEY=
# DAYTONA_API_URL=
# DAYTONA_TARGET=
# DAYTONA_NETWORK_BLOCK_ALL=false
# DAYTONA_NETWORK_ALLOW_LIST=
# DAYTONA_RESOURCE_CPU=
# DAYTONA_RESOURCE_MEMORY=
# DAYTONA_RESOURCE_DISK=
# DAYTONA_RETAIN_SANDBOXES=false

# Sentry operational telemetry
# Local development defaults to local Effect JSONL logs. Set Sentry values for production/server telemetry.
# SENTRY_DSN=
# SENTRY_ENABLED=true
# SENTRY_ENVIRONMENT=development
# SENTRY_LOG_LEVEL=Debug
# SENTRY_ENABLE_LOGS=false
# SENTRY_ENABLE_TRACING=true
# SENTRY_ENABLE_METRICS=false
# SENTRY_TRACES_SAMPLE_RATE=1.0

# Cloudflare infra provisioning via apps/infra / Alchemy
# Required only when running infra commands: bun run infra:plan|deploy|destroy
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Required for signed evidence artifact URLs. Artifact capture itself uses the native R2 binding.
# CLOUDFLARE_ACCESS_KEY_ID=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# Optional PatchPlane-specific names override the generic Cloudflare S3 credentials.
# PATCHPLANE_EVIDENCE_R2_ACCESS_KEY_ID=
# PATCHPLANE_EVIDENCE_R2_SECRET_ACCESS_KEY=

# Optional provider/model selection for Daytona Pi mode. Defaults to openai/gpt-5.5.
# PATCHPLANE_PI_PROVIDER=openai
# PATCHPLANE_PI_MODEL=gpt-5.5
# PATCHPLANE_PI_THINKING=low
# PATCHPLANE_PI_MODE=json

# Optional Cloudflare AI Gateway routing for Pi mode.
# When CLOUDFLARE_API_KEY, CLOUDFLARE_ACCOUNT_ID, and CLOUDFLARE_GATEWAY_ID or
# PATCHPLANE_AI_GATEWAY_ID are present, Pi runs with provider=cloudflare-ai-gateway.
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_GATEWAY_ID=
# PATCHPLANE_AI_GATEWAY_ID=

# Optional direct provider keys for Pi modes and local/debug fallback
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# COPILOT_GITHUB_TOKEN=
