{
  "name": "@patchplane/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev",
    "test": "vitest run",
    "typecheck": "bun run typecheck:convex",
    "typecheck:convex": "tsc --project convex/tsconfig.json --noEmit",
    "lint": "oxlint convex src && bun run lint:convex",
    "lint:convex": "eslint convex --max-warnings=0",
    "lint:convex:fix": "eslint convex --max-warnings=0 --fix",
    "format": "oxfmt convex src"
  },
  "dependencies": {
    "@convex-dev/workos-authkit": "^0.2.7",
    "@daytona/sdk": "^0.186.0",
    "@patchplane/domain": "workspace:*",
    "convex": "^1.41.0",
    "effect": "4.0.0-beta.90",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@patchplane/typescript-config": "workspace:*",
    "@types/node": "^25.9.3",
    "convex-test": "^0.0.53",
    "eslint": "^10.4.1",
    "eslint-plugin-oxlint": "^1.69.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
