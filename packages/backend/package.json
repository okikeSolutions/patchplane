{
  "name": "@patchplane/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev",
    "test": "bun test",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "typecheck:convex": "tsc --project convex/tsconfig.json --noEmit",
    "lint": "oxlint convex src && bun run lint:convex",
    "lint:convex": "eslint convex --max-warnings=0",
    "lint:convex:fix": "eslint convex --max-warnings=0 --fix",
    "format": "oxfmt convex src"
  },
  "dependencies": {
    "@convex-dev/workos-authkit": "^0.1.6",
    "@daytonaio/sdk": "^0.155.0",
    "@patchplane/domain": "workspace:*",
    "convex": "latest",
    "effect": "3.21.0",
    "octokit": "^5.0.3"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.1",
    "@eslint/js": "^9.39.0",
    "@patchplane/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.0",
    "eslint-plugin-oxlint": "^1.57.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
